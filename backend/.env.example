APP_NAME=Atlas
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Empty/unset = trust no proxies (correct for local/testing, where no
# reverse proxy exists). In production, once a real reverse proxy/load
# balancer is provisioned, set this to its IP(s)/CIDR range(s), comma-
# separated — or to the literal value "*" to trust whichever machine is
# directly connecting (the standard choice for a single-hop proxy whose own
# IP isn't fixed, e.g. Forge/most managed load balancers). Left unset in
# production, HTTPS detection, HSTS, client IP resolution, and IP-keyed rate
# limiting will all use the proxy's IP/scheme instead of the real client's.
# See docs/deployment/Production-Topology.md and
# docs/plans/Critical-Production-Blockers.md, Blocker 7.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=atlas
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database: jobs run via a queue worker — start one with `composer dev` or:
#   php artisan queue:work --queue=high,ai,default,observations,publishing,analytics,maintenance
# redis: production mode — same worker requirement, backed by Redis.
# sync: runs jobs inline in the HTTP request. Do NOT use for onboarding —
#   the crawl + AI pipeline blocks the request for minutes and causes 502s.
QUEUE_CONNECTION=database

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Safe local/test default — never delivers real email. In production, set
# MAIL_MAILER=postmark and the two POSTMARK_* variables below; a boot-time
# guard (App\Services\Mail\ProductionMailerGuard) refuses to send password
# reset email if production is left on log/array. See
# docs/plans/Critical-Production-Blockers.md, Blocker 6.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="atlas@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Postmark — required only when MAIL_MAILER=postmark.
POSTMARK_API_KEY=
POSTMARK_MESSAGE_STREAM_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Error tracking — 'null' (no-op) until a real vendor is wired in. See
# docs/plans/Critical-Production-Blockers.md, Blocker 5, for activation steps.
ERROR_TRACKING_DRIVER=null
ERROR_TRACKING_DSN=
